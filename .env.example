# =============================================================================
# luis_ruiz_2 environment template
# Generated from current code usage audit on 2026-04-12.
# Fill this into .env.local for development or your deployment secret store.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE APP RUNTIME (required)
# -----------------------------------------------------------------------------
# Required by next.config.ts, Supabase browser client, middleware, auth callback,
# and most site functionality.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Strongly recommended for full server/admin behavior.
# Prefer SUPABASE_SERVICE_ROLE_KEY over SUPABASE_API_KEY.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_API_KEY=
SUPABASE_URL=

# Owner-only admin access control (comma-separated emails)
OWNER_EMAILS=

# Canonical site URL for redirects, auth flows, and Stripe callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:5000
SITE_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# SUPABASE AUTH / JWT (optional, defaults can be derived from Supabase URL)
# -----------------------------------------------------------------------------
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_URL=

# -----------------------------------------------------------------------------
# SUPABASE STORAGE / PHOTOS (optional unless using photo flows)
# -----------------------------------------------------------------------------
SUPABASE_PHOTOS_BUCKET=photos
SUPABASE_SIGNED_URL_EXPIRES=3600

# -----------------------------------------------------------------------------
# AI PROVIDERS (optional, enable the providers you actually use)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GEMINI_API_KEY=

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

HF_API_KEY=
HF_MODEL=HuggingFaceH4/zephyr-7b-beta

XAI_API_KEY=

# Optional local Ollama endpoint, defaults to http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# VECTOR / RAG FEATURES (optional, required for Pinecone-backed flows)
# -----------------------------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=

# -----------------------------------------------------------------------------
# SEARCH (optional)
# -----------------------------------------------------------------------------
BRAVE_API_KEY=

# -----------------------------------------------------------------------------
# GITHUB INTEGRATION (optional, required for GitHub proxy / mutating GitHub ops)
# -----------------------------------------------------------------------------
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2022-11-28
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_PROXY_SECRET=
BUILD_LOG_GITHUB_REPO=ruizTechServices/luis_ruiz_2
BUILD_LOG_GITHUB_BRANCH=GioClaw-Edit
BUILD_LOG_NOTION_PAGE_ID=34161db1-6a30-81e3-a939-c468547cdb7d

# -----------------------------------------------------------------------------
# STRIPE / NUCLEUS PAYMENTS (optional, required only for payment flows)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# NUCLEUS AUTH / RATE LIMITING / CORS (optional unless using those routes)
# -----------------------------------------------------------------------------
# Upstash Redis or Vercel KV for distributed rate limiting.
# If unset, code falls back to in-memory limiting.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
NUCLEUS_RATE_LIMIT_MAX=60
NUCLEUS_RATE_LIMIT_WINDOW_MS=60000

# Comma-separated allowed origins, or * for local development only.
NUCLEUS_CORS_ORIGINS=https://luis-ruiz.com,https://www.luis-ruiz.com

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. DATABASE_URL and DIRECT_URL are not used by the current codebase.
# 2. CALLBACK_URI, GOOGLE_PRODUCTION_CLIENT_ID, and GOOGLE_PRODUCTION_CLIENT_SECRET
#    are not referenced by the current audited app code.
# 3. For migration/admin work from a shell, the practical minimum is:
#    NEXT_PUBLIC_SUPABASE_URL (or SUPABASE_URL) + SUPABASE_SERVICE_ROLE_KEY.
